app_identifier("com.splitkaro") # Android applicationId. iOS bundle id is still the RN template default — set PRODUCT_BUNDLE_IDENTIFIER in Xcode before shipping to the App Store.
apple_id(ENV["APPLE_ID"]) # set in CI env / your shell profile, not committed
team_id(ENV["APPLE_TEAM_ID"])

for_platform :android do
  json_key_file(ENV["PLAY_STORE_JSON_KEY"]) # Play Console service-account key, path only — never commit the key itself
  package_name("com.splitkaro")
end
